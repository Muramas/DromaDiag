<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- net48 matches Unity Mono's runtime on Windows; change to net6.0+ if you prefer a self-contained build -->
    <TargetFramework>net48</TargetFramework>
    <AssemblyName>DromadSpy</AssemblyName>
    <RootNamespace>DromadSpy</RootNamespace>
    <Nullable>disable</Nullable>
    <LangVersion>8.0</LangVersion>
    <!-- Produce a single output folder that DromaDiag can point at -->
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <!-- ILSpy's standalone decompiler engine — no WPF dependency -->
    <PackageReference Include="ICSharpCode.Decompiler" Version="8.2.0.7535" />
  </ItemGroup>

</Project>
